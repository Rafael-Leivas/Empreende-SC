generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Segmento {
  TECNOLOGIA
  COMERCIO
  INDUSTRIA
  SERVICOS
  AGRONEGOCIO
}

model Empreendimento {
  id            Int       @id @default(autoincrement())
  nome          String
  empreendedor  String
  municipio     String
  segmento      Segmento
  contato       String
  ativo         Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Municipio {
  id   Int    @id @default(autoincrement())
  nome String @unique
}
